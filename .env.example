# ============================================
# Office Pet API - Environment Variables
# ============================================
# NOTA: Este archivo es un EJEMPLO. Copia esto a .env y ajusta los valores
# según tu entorno local. NUNCA commits el archivo .env a Git.

# ============================================
# Database Configuration
# ============================================
# Formato: postgresql://usuario:contraseña@host:puerto/nombre_bd?schema=public
# 
# Si usas Docker Compose:
#   - Usuario: user_office
#   - Contraseña: password123
#   - Host: localhost
#   - Puerto: 5435
#   - Base de datos: office_pets_db
DATABASE_URL="postgresql://user_office:password123@localhost:5435/office_pets_db?schema=public"

# ============================================
# JWT Configuration
# ============================================
# Secreto para firmar tokens JWT
# EN PRODUCCIÓN: Usa un valor largo, aleatorio y seguro
# Ejemplo en producción: $(openssl rand -base64 32)
JWT_SECRET="super-secret-key-office-2026"

# ============================================
# Application Configuration
# ============================================
# Entorno de ejecución: development | production | test
NODE_ENV="development"

# Puerto donde corre la aplicación
PORT=3000

# ============================================
# Logs (Opcional)
# ============================================
# LOG_LEVEL="debug"  # debug | log | warn | error | fatal
